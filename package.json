	"name": "report-wiza",
	"private": true,
	"proxy": "http://localhost:3000",
	"scripts": {
		"build": "react-scripts build",
		"dev": "react-scripts start",
		"eject": "react-scripts eject",
		"format": "prettier --write \"**/*.js\" \"**/*.html\" \"**/*.css\" \"*.js\"",
		"format:check": "prettier --check \"**/*.js\" \"**/*.html\" \"**/*.css\" \"*.js\"",
		"lint": "eslint .",
		"start": "node server.js",
		"test": "react-scripts test --passWithNoTests",
		"test:coverage": "react-scripts test --coverage --watchAll=false --passWithNoTests",
		"test:coverage:watch": "react-scripts test --coverage --passWithNoTests"
	},
	"type": "module",
	"version": "0.1.0"
