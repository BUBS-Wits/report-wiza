		"eslint": "^9.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.0.1",
		"esri-leaflet": "^3.0.19",
		"express": "^5.2.1",
		"firebase": "^12.11.0",
		"firebase-admin": "^13.8.0",
		"leaflet": "^1.9.4",
		"prettier": "^3.8.2",
		"react": "^19.2.4",
