// src/tests/public_dashboard.test.js
import React from 'react';
import { render } from '@testing-library/react';
import PublicDashboard from '../pages/public_dashboard/public_dashboard';

// Mock all Firebase Firestore functions
jest.mock('firebase/firestore', () => ({
  collection: jest.fn(),
  getDocs: jest.fn().mockResolvedValue({ docs: [] }),
}));

// Mock the Firebase config
jest.mock('../firebase_config', () => ({
  db: {},
}));

// Mock react-router-dom (without using Link, just provide empty object)
jest.mock('react-router-dom', () => ({}));

// Mock leaflet and react-leaflet
jest.mock('react-leaflet', () => ({
  MapContainer: ({ children }) => <div>{children}</div>,
  TileLayer: () => null,
  Marker: () => null,
  Popup: () => null,
  useMap: () => ({ invalidateSize: jest.fn() }),
}));
jest.mock('leaflet', () => ({}));
jest.mock('esri-leaflet', () => ({}));

// Mock RequestCard component
jest.mock('../components/request_card/request_card.js', () => () => <div />);

test('renders without crashing', () => {
  render(<PublicDashboard />);
});