// src/tests/public_dashboard.test.js
import React from 'react';
import { render, screen, waitFor } from '@testing-library/react';
import '@testing-library/jest-dom';
import PublicDashboard from '../pages/public_dashboard/public_dashboard';
import { db } from '../firebase_config';
import { collection, getDocs } from 'firebase/firestore';

// --- Mocks for external dependencies ---
jest.mock('../firebase_config', () => ({
  db: {},
}));
jest.mock('firebase/firestore', () => ({
  collection: jest.fn(),
  getDocs: jest.fn(),
}));

// Mock leaflet and react-leaflet
jest.mock('react-leaflet', () => ({
  MapContainer: ({ children }) => <div data-testid="map-container">{children}</div>,
  TileLayer: () => null,
  Marker: () => null,
  Popup: () => null,
  useMap: () => ({ invalidateSize: jest.fn() }),
}));
jest.mock('leaflet', () => ({
  Icon: class {},
  Default: { prototype: { _getIconUrl: null }, mergeOptions: jest.fn() },
  latLngBounds: jest.fn(() => ({})),
}));
jest.mock('esri-leaflet', () => ({
  featureLayer: jest.fn(() => ({
    bindPopup: jest.fn().mockReturnThis(),
    on: jest.fn().mockReturnThis(),
    addTo: jest.fn().mockReturnThis(),
    resetStyle: jest.fn(),
  })),
}));

// Mock RequestCard component
jest.mock('../components/request_card/request_card.js', () => ({ request }) => (
  <div data-testid="request-card">{request.category}</div>
));

describe('PublicDashboard', () => {
  beforeEach(() => {
    jest.clearAllMocks();
  });

  const mockFirestoreData = (docs) => {
    getDocs.mockResolvedValue({
      docs: docs.map(doc => ({
        id: doc.id,
        data: () => doc.data,
      })),
    });
  };

  it('shows loading state initially', () => {
    getDocs.mockImplementation(() => new Promise(() => {}));
    render(<PublicDashboard />);
    expect(screen.getByText(/Loading dashboard.../i)).toBeInTheDocument();
  });

  it('shows error message when Firestore fetch fails', async () => {
    getDocs.mockRejectedValue(new Error('Network error'));
    render(<PublicDashboard />);
    expect(await screen.findByText(/Could not load requests. Please try again later./i)).toBeInTheDocument();
  });

  it('splits requests into open and resolved correctly', async () => {
    const mockDocs = [
      { id: '1', data: { status: 'Open', category: 'Potholes', like_count: 0 } },
      { id: '2', data: { status: 'Resolved', category: 'Water', like_count: 0 } },
      { id: '3', data: { status: 'In Progress', category: 'Electricity', like_count: 0 } },
    ];
    mockFirestoreData(mockDocs);
    render(<PublicDashboard />);
    await waitFor(() => {
      expect(screen.getByTestId('map-container')).toBeInTheDocument();
    });
    // Open requests count = 2 (Open + In Progress)
    expect(screen.getByText('2')).toBeInTheDocument();
    // Resolved requests count = 1
    expect(screen.getByText('1')).toBeInTheDocument();
    expect(screen.getAllByTestId('request-card')).toHaveLength(3);
  });

  it('displays distinct ward count correctly', async () => {
    const mockDocs = [
      { id: '1', data: { status: 'Open', ward: 'Ward 60' } },
      { id: '2', data: { status: 'Resolved', ward: 'Ward 60' } },
      { id: '3', data: { status: 'Open', ward: 'Ward 61' } },
    ];
    mockFirestoreData(mockDocs);
    render(<PublicDashboard />);
    await waitFor(() => {
      expect(screen.getByTestId('map-container')).toBeInTheDocument();
    });
    expect(screen.getByText('2')).toBeInTheDocument(); // distinct wards: 60 and 61
  });
});

// Optional: WKT parser test
describe('parseWktPoint helper', () => {
  const parseWktPoint = (locationStr) => {
    if (!locationStr) return null;
    const match = locationStr.match(/POINT\(([-\d.]+)\s+([-\d.]+)\)/i);
    if (match) {
      const lon = parseFloat(match[1]);
      const lat = parseFloat(match[2]);
      if (!isNaN(lat) && !isNaN(lon)) return { lat, lon };
    }
    return null;
  };

  it('parses valid WKT string', () => {
    const result = parseWktPoint('SRID=4326;POINT(28.0456 -26.2044)');
    expect(result).toEqual({ lat: -26.2044, lon: 28.0456 });
  });

  it('returns null for invalid input', () => {
    expect(parseWktPoint('invalid')).toBeNull();
    expect(parseWktPoint('')).toBeNull();
    expect(parseWktPoint(null)).toBeNull();
  });
});